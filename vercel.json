{
  "buildCommand": "rm -rf dist && mkdir -p dist && cp -r website/. dist/",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/privacy", "dest": "/privacy.html" },
    { "src": "/terms", "dest": "/terms.html" },
    { "src": "/support", "dest": "/support.html" },
    { "src": "/(favicon\\.png|style\\.css)", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}

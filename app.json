{
  "expo": {
    "name": "5tepTracker",
    "slug": "StepTracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "steptracker",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090B"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMotionUsageDescription": "5tepTracker uses motion data to count your steps.",
        "NSLocationWhenInUseUsageDescription": "5tepTracker uses your location to track runs and walks.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "5tepTracker uses background location to track runs even when the app is closed.",
        "NSCameraUsageDescription": "5tepTracker uses the camera to take profile photos.",
        "NSPhotoLibraryUsageDescription": "5tepTracker accesses your photos for your profile picture."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.steptracker.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "backgroundColor": "#09090B"
      },
      "permissions": [
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_TOTAL_CALORIES_BURNED"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "minSdkVersion": 26
          }
        }
      ],
      [
        "react-native-health",
        {
          "isClinicalDataEnabled": false,
          "permissions": {
            "read": ["StepCount"]
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "5tepTracker uses background location to track your runs.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "./plugins/health-connect",
      [
        "expo-sensors",
        {
          "motionPermission": "5tepTracker uses motion to count your steps."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "5tepTracker accesses your photos for your profile picture.",
          "cameraPermission": "5tepTracker uses the camera to take profile photos."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#A855F7"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e5aa7eb2-9903-475b-9836-df371134c63b"
      }
    }
  }
}
